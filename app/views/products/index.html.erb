<p style="color: green"><%= notice %></p>

<% content_for :title, "Products" %>

<h1>Products</h1>

<div id="products">
  <% @products.each do |product| %>
    <%= render product %>
    <p>
      <%= link_to "Show this product", product %>
    </p>
  <% end %>
</div>

<%= link_to "New product", new_product_path %>

<h2>Integrations</h2>
<div data-controller="products" data-project-id="<%= ENV['PARAGON_PROJECT_ID'] %>" data-token="<%= @paragon_user_token %>" data-no-transition-cache>
  Loading integrations...
</div>
